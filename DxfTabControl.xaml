<UserControl x:Class="DxfViewer.DxfTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DxfViewer"
             Background="#12121E">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Content row: canvas + layer panel side by side -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition x:Name="LayerPanelCol" Width="200"/>
      </Grid.ColumnDefinitions>

      <!-- Loading state -->
      <StackPanel Grid.Column="0"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
        <TextBlock Text="Loading..." FontSize="16" Foreground="#888" HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Error state -->
      <StackPanel Grid.Column="0"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  Visibility="{Binding IsError, Converter={StaticResource BoolToVisibility}}"
                  MaxWidth="600">
        <TextBlock Text="Failed to load file" FontSize="16" Foreground="#CC4444" HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#AA6666"
                   HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
      </StackPanel>

      <!-- SkiaSharp canvas -->
      <Grid Grid.Column="0" x:Name="SkiaHost"
            Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibility}}"
            Background="#12121E"
            SizeChanged="SkiaHost_SizeChanged"
            MouseDown="Canvas_MouseDown"
            MouseMove="Canvas_MouseMove"
            MouseUp="Canvas_MouseUp"
            MouseWheel="Canvas_MouseWheel"
            Focusable="True">
        <Image x:Name="SkiaImage" Stretch="Fill"/>
      </Grid>

      <!-- Layers panel -->
      <Border Grid.Column="1" Background="#1E1E30"
              BorderBrush="#303048" BorderThickness="1,0,0,0">
        <DockPanel>

          <!-- Chevron toggle on left edge of panel -->
          <Button x:Name="LayerToggleBtn"
                  DockPanel.Dock="Left"
                  Width="20"
                  Content="&#9664;"
                  Click="LayerToggle_Click"
                  Background="#1E1E30"
                  Foreground="#9090A0"
                  BorderThickness="0"
                  FontSize="10"
                  VerticalContentAlignment="Center"
                  HorizontalContentAlignment="Center"
                  Cursor="Hand"/>

          <!-- Panel body (hidden when collapsed) -->
          <Grid x:Name="LayerPanelBody">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="1"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="LAYERS"
                       Foreground="#9090A0" FontSize="11"
                       FontFamily="Segoe UI"
                       Margin="8,8,8,4"/>

            <!-- All On / All Off buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,4" HorizontalAlignment="Left">
              <Button Content="All On"
                      Command="{Binding AllLayersOnCommand}"
                      Padding="6,2" Margin="0,0,4,0"
                      FontSize="10"
                      Background="#252540" Foreground="#D0D0E0"
                      BorderBrush="#404055" BorderThickness="1"/>
              <Button Content="All Off"
                      Command="{Binding AllLayersOffCommand}"
                      Padding="6,2"
                      FontSize="10"
                      Background="#252540" Foreground="#D0D0E0"
                      BorderBrush="#404055" BorderThickness="1"/>
            </StackPanel>

            <!-- Separator -->
            <Border Grid.Row="3" Background="#303048"/>

            <!-- Layer list -->
            <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding Layers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type local:LayerInfo}">
                    <Grid Height="28">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <CheckBox Grid.Column="0"
                                IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                Margin="8,0,4,0"/>
                      <Ellipse Grid.Column="1"
                               Width="8" Height="8"
                               Fill="{Binding ColorBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                      <TextBlock Grid.Column="2"
                                 Text="{Binding Name}"
                                 Foreground="#D0D0E0"
                                 FontSize="11"
                                 FontFamily="Segoe UI"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Bottom nav bar -->
    <Border Grid.Row="1" Background="#252525" BorderBrush="#444" BorderThickness="0,1,0,0" Padding="6,4">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <Button Style="{StaticResource NavButton}"
                  Content="&#9664;"
                  Command="{Binding NavPrevCommand}"
                  ToolTip="Previous file (left arrow)"/>
          <Button Style="{StaticResource NavButton}"
                  Content="&#9654;"
                  Command="{Binding NavNextCommand}"
                  ToolTip="Next file (right arrow)"/>
        </StackPanel>
        <TextBlock Text="{Binding FilePath}"
                   Foreground="#666" FontSize="11"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   DockPanel.Dock="Right"
                   TextTrimming="CharacterEllipsis"
                   Margin="8,0,0,0"/>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
