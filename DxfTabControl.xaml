<UserControl x:Class="DxfViewer.DxfTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#12121E">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Loading state -->
    <StackPanel Grid.Row="0"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
      <TextBlock Text="Loading…" FontSize="16" Foreground="#888" HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Error state -->
    <StackPanel Grid.Row="0"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{Binding IsError, Converter={StaticResource BoolToVisibility}}"
                MaxWidth="600">
      <TextBlock Text="Failed to load file" FontSize="16" Foreground="#CC4444" HorizontalAlignment="Center"/>
      <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#AA6666"
                 HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
    </StackPanel>

    <!-- SkiaSharp canvas — rendered into a WriteableBitmap displayed in an Image -->
    <Grid Grid.Row="0" x:Name="SkiaHost"
          Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibility}}"
          Background="#12121E"
          SizeChanged="SkiaHost_SizeChanged"
          MouseDown="Canvas_MouseDown"
          MouseMove="Canvas_MouseMove"
          MouseUp="Canvas_MouseUp"
          MouseWheel="Canvas_MouseWheel"
          Focusable="True">
      <Image x:Name="SkiaImage" Stretch="Fill"/>
    </Grid>

    <!-- Bottom nav bar -->
    <Border Grid.Row="1" Background="#252525" BorderBrush="#444" BorderThickness="0,1,0,0" Padding="6,4">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
          <Button Style="{StaticResource NavButton}"
                  Content="◀"
                  Command="{Binding NavPrevCommand}"
                  ToolTip="Previous file (←)"/>
          <Button Style="{StaticResource NavButton}"
                  Content="▶"
                  Command="{Binding NavNextCommand}"
                  ToolTip="Next file (→)"/>
        </StackPanel>
        <TextBlock Text="{Binding FilePath}"
                   Foreground="#666" FontSize="11"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   DockPanel.Dock="Right"
                   TextTrimming="CharacterEllipsis"
                   Margin="8,0,0,0"/>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
