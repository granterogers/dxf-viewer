<Window x:Class="DxfViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DxfViewer"
        Title="Microvellum DXF Viewer v1.3"
        Width="1200" Height="800"
        Background="#1E1E1E"
        AllowDrop="True"
        Topmost="{Binding AlwaysOnTop}">

  <Window.InputBindings>
    <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
    <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}"/>
    <KeyBinding Key="Tab" Modifiers="Ctrl" Command="{Binding NextTabCommand}"/>
    <KeyBinding Key="Tab" Modifiers="Ctrl+Shift" Command="{Binding PrevTabCommand}"/>
  </Window.InputBindings>

  <DockPanel>
    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Background="#252535" BorderBrush="#444" BorderThickness="0,0,0,1">
      <!-- Orange accent line at very top (INNERGY brand) -->
      <DockPanel>
        <Border DockPanel.Dock="Top" Height="3" Background="#E07820"/>
        <DockPanel Margin="6,4">

          <!-- Right: INNERGY branding -->
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,4,0">
            <TextBlock Text="INNERGY"
                       Foreground="#E07820"
                       FontFamily="Segoe UI"
                       FontSize="11"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Opacity="0.9"/>
          </StackPanel>

          <!-- Left: action buttons -->
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Navigation buttons first -->
            <Button Style="{StaticResource ToolbarButton}"
                    Content="&#9664; Previous Drawing"
                    Command="{Binding NavPrevCommand}"
                    ToolTip="Previous drawing (&#8592;)"/>
            <Button Style="{StaticResource ToolbarButton}"
                    Content="Next Drawing &#9654;"
                    Command="{Binding NavNextCommand}"
                    ToolTip="Next drawing (&#8594;)"/>

            <!-- File / view actions -->
            <Button Style="{StaticResource ToolbarButton}"
                    Content="Open File"
                    Command="{Binding OpenFileCommand}"/>
            <Button Style="{StaticResource ToolbarButton}"
                    Content="Fit Drawing to Page"
                    Command="{Binding FitCommand}"
                    ToolTip="Fit the drawing to the window (F)"/>
            <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                          Content="Always on Top"
                          Command="{Binding ToggleAlwaysOnTopCommand}"
                          IsChecked="{Binding AlwaysOnTop, Mode=OneWay}"
                          ToolTip="Keep this window above all others"/>

            <!-- Divider -->
            <Border Width="1" Background="#2A4A70" Margin="6,3"/>

            <!-- Open with Microvellum -->
            <Button Style="{StaticResource ToolbarButton}"
                    Content="Open with Microvellum"
                    Command="{Binding OpenWithMicrovellumCommand}"
                    Background="#0D47A1"
                    BorderBrush="#082F6B"
                    Margin="2,0,0,0"
                    ToolTip="Open the current DXF in Microvellum"/>
          </StackPanel>

        </DockPanel>
      </DockPanel>
    </Border>

    <!-- Main content area -->
    <Grid>
      <!-- Empty state -->
      <StackPanel x:Name="EmptyState"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  Visibility="{Binding EmptyStateVisibility}">
        <TextBlock Text="No files open"
                   FontSize="22" FontWeight="Light"
                   Foreground="#555" HorizontalAlignment="Center"/>
        <TextBlock Text="Drag a DXF file here or press Ctrl+O to open one"
                   FontSize="14" Foreground="#444"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
      </StackPanel>

      <!-- Tab control -->
      <TabControl x:Name="MainTabControl"
                  Visibility="{Binding TabsVisibility}"
                  VerticalContentAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  ItemsSource="{Binding Tabs}"
                  SelectedItem="{Binding ActiveTab}">
        <TabControl.ItemTemplate>
          <DataTemplate DataType="{x:Type local:DxfTabViewModel}">
            <StackPanel x:Name="TabHeader" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock x:Name="TabTitle"
                         Text="{Binding Title}"
                         FontFamily="Segoe UI" FontSize="12"
                         VerticalAlignment="Center"
                         Foreground="#9090A0"
                         MaxWidth="180"
                         TextTrimming="CharacterEllipsis"/>
              <Button x:Name="CloseBtn"
                      Style="{StaticResource TabCloseButton}"
                      Content="&#215;"
                      Command="{Binding DataContext.CloseTabCommand,
                                RelativeSource={RelativeSource AncestorType=TabControl}}"
                      CommandParameter="{Binding}"/>
            </StackPanel>
            <DataTemplate.Triggers>
              <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                <Setter TargetName="TabTitle" Property="Foreground" Value="#FFFFFF"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="True">
                <Setter TargetName="CloseBtn" Property="Opacity" Value="1"/>
              </DataTrigger>
            </DataTemplate.Triggers>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate DataType="{x:Type local:DxfTabViewModel}">
            <local:DxfTabControl/>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
